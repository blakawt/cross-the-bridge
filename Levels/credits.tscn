[gd_scene format=3 uid="uid://cxs41r2xnrprn"]

[sub_resource type="Shader" id="Shader_ouk20"]
code = "shader_type canvas_item;

// Uniformes pour contrôler le shader depuis l'inspecteur Godot
uniform vec4 base_color_mod : source_color = vec4(0.4, 0.6, 1.0, 1.0);
uniform float speed_multiplier : hint_range(0.0, 2.0) = 0.1;
uniform float num_layers : hint_range(1.0, 10.0) = 4.0;
uniform sampler2D screen_texture : hint_screen_texture, repeat_disable, filter_nearest;

#define S(a, b, t) smoothstep(a, b, t)

float N21(vec2 p) {
    vec3 a = fract(vec3(p.xyx) * vec3(213.897, 653.453, 253.098));
    a += dot(a, a.yzx + 79.76);
    return fract((a.x + a.y) * a.z);
}

vec2 GetPos(vec2 id, vec2 offs, float t) {
    float n = N21(id + offs);
    float n1 = fract(n * 10.0);
    float n2 = fract(n * 100.0);
    float a = t + n;
    return offs + vec2(sin(a * n1), cos(a * n2)) * 0.4;
}

float df_line(vec2 a, vec2 b, vec2 p) {
    vec2 pa = p - a, ba = b - a;
    float h = clamp(dot(pa, ba) / dot(ba, ba), 0.0, 1.0);    
    return length(pa - ba * h);
}

float line(vec2 a, vec2 b, vec2 uv) {
    float r1 = 0.04;
    float r2 = 0.01;
    float d = df_line(a, b, uv);
    float d2 = length(a - b);
    float fade = S(1.5, 0.5, d2);
    fade += S(0.05, 0.02, abs(d2 - 0.75));
    return S(r1, r2, d) * fade;
}

float NetLayer(vec2 st, float n, float t) {
    vec2 id = floor(st) + n;
    st = fract(st) - 0.5;
    
    vec2 p[9];
    int i = 0;
    for(float y = -1.0; y <= 1.0; y++) {
        for(float x = -1.0; x <= 1.0; x++) {
            p[i++] = GetPos(id, vec2(x, y), t);
        }
    }
    
    float m = 0.0;
    float sparkle = 0.0;
    
    for(int j = 0; j < 9; j++) {
        m += line(p[4], p[j], st);
        float d = length(st - p[j]);
        float s = (0.005 / (d * d));
        s *= S(1.0, 0.7, d);
        float pulse = sin((fract(p[j].x) + fract(p[j].y) + t) * 5.0) * 0.4 + 0.6;
        pulse = pow(pulse, 20.0);
        s *= pulse;
        sparkle += s;
    }
    
    m += line(p[1], p[3], st);
    m += line(p[1], p[5], st);
    m += line(p[7], p[5], st);
    m += line(p[7], p[3], st);
    
    float sPhase = (sin(t + n) + sin(t * 0.1)) * 0.25 + 0.5;
    sPhase += pow(sin(t * 0.1) * 0.5 + 0.5, 50.0) * 5.0;
    m += sparkle * sPhase;
    
    return m;
}

void fragment() {
    // iResolution -> 1.0 / SCREEN_PIXEL_SIZE (pour CanvasItem)
    vec2 uv = (FRAGCOORD.xy - (1.0 / SCREEN_PIXEL_SIZE).xy * 0.5) / (1.0 / SCREEN_PIXEL_SIZE).y;
    
    // Remplacement de iMouse (peut être passé via script si besoin, ici statique)
    vec2 M = vec2(0.0); 
    
    float t = TIME * speed_multiplier;
    float s = sin(t);
    float c = cos(t);
    mat2 rot = mat2(vec2(c, -s), vec2(s, c));
    vec2 st = uv * rot;  
    M *= rot * 2.0;
    
    float m = 0.0;
    for(float i = 0.0; i < 1.0; i += 1.0 / num_layers) {
        float z = fract(t + i);
        float size = mix(15.0, 1.0, z);
        float fade = S(0.0, 0.6, z) * S(1.0, 0.8, z);
        m += fade * NetLayer(st * size - M * z, i, TIME);
    }
    
    // Simulation du FFT (musique) simplifiée car Godot ne l'envoie pas par défaut
    float glow = -uv.y * 0.1; 
   
    vec3 baseCol = vec3(s, cos(t * 0.4), -sin(t * 0.24)) * 0.4 + 0.6;
    vec3 col = baseCol * m;
    col += baseCol * glow;
    
    col *= 1.0 - dot(uv, uv); // Vignette
    
    // Fade in/out temporel (optionnel)
    float t_mod = mod(TIME, 230.0);
    col *= S(0.0, 20.0, t_mod) * S(224.0, 200.0, t_mod);
    
    COLOR = vec4(col * base_color_mod.rgb, 1.0);
}"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_3npp4"]
shader = SubResource("Shader_ouk20")
shader_parameter/base_color_mod = Color(0.4, 0.6, 1, 1)
shader_parameter/speed_multiplier = 0.1
shader_parameter/num_layers = 4.0

[sub_resource type="GDScript" id="GDScript_3npp4"]
script/source = "extends Label

@export var speed := 50.0

func _process(delta):
	position.y -= speed * delta
"

